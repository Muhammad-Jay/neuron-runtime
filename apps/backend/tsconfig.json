{
  "compilerOptions": {
    /* File Layout */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Environment Settings */
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2020",
    "lib": ["esnext"],
    "types": ["node"], // MUST be uncommented for Node.js APIs

    /* Other Outputs */
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    /* Stricter Typechecking Options */
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    /* Recommended Options */
    "strict": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "esModuleInterop": true, // Add this for Express compatibility,
    "paths": {
      "@shared/*": ["../shared/src/*"]
    }
  },
  "references": [
    {
      "path": "../shared"
    }
  ],
  "include": ["src/**/*", "../shared/src/**/*"]
}
