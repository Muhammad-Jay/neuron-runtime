{
  "compilerOptions": {
    "composite": true,
    "declaration": true,

    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@neuron/shared": ["../../packages/shared/dist"],
      "@neuron/shared/*": ["../../packages/shared/dist/*"]
    },

    "module": "CommonJS",
    "target": "ES2020",

    "strict": true,
    "esModuleInterop": true
  },
  "include": ["src"]
}