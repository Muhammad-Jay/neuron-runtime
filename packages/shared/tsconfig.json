{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "target": "ES2020",

    "declaration": true,
    "declarationMap": true,

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}